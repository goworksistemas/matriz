      {
        "parameters": {
          "jsCode": "const items = $input.all();\nconst comments = [];\nfor (const item of items) {\n  const results = item.json.results || [];\n  for (const c of results) {\n    const richText = c.rich_text || [];\n    const text = richText.map(rt => rt.plain_text || '').join('');\n    comments.push({\n      json: {\n        comment_id: c.id || '',\n        notion_id: c.parent?.page_id || '',\n        text,\n        author: c.created_by?.name || '',\n        commented_at: c.created_time || null,\n        _extracted_at: new Date().toISOString()\n      }\n    });\n  }\n}\nif (comments.length === 0) return [];\nreturn comments;"
        },
