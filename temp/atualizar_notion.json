          "jsCode": "const items = $input.all();\n\nconst porNotionId = new Map();\nfor (const item of items) {\n  const row = item.json || {};\n  const notionId = row.notion_id || '';\n  if (!notionId) continue;\n  porNotionId.set(notionId, row);\n}\n\nconst batch = Array.from(porNotionId.values());\nif (batch.length === 0) {\n  return [];\n}\n\nreturn [{ json: { batch } }];"
