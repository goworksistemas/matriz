      {
        "parameters": {
          "jsCode": "const notionItems = $('Notion - Get All Tasks').all();\nconst notionIds = new Set();\nfor (const item of notionItems) {\n  const id = (item.json?.id || '').replace(/-/g, '');\n  if (id) notionIds.add(id);\n}\n\nconst supabaseItems = $('Supabase GET All Tasks').all();\n\nconst removidas = [];\nfor (const item of supabaseItems) {\n  const t = item.json;\n  const nid = (t.notion_id || '').replace(/-/g, '');\n  if (!nid) continue;\n  if (!notionIds.has(nid)) {\n    removidas.push({\n      json: {\n        notion_id: t.notion_id,\n        title: t.title || '(sem titulo)',\n        executor: t.executor || '-',\n        requester: t.requester || '-',\n        created_by: t.created_by || '-',\n        department: t.department || '-'\n      }\n    });\n  }\n}\n\nreturn removidas;"
        },
